# Data files — never commit raw or cleaned survey data
/r/data/
/r/output/
/r/clean/
/r/output/*.csv
/r/output/*.rds
/r/output/*.rda
/r/output/*.sav
*.csv
*.rds
*.rda
*.sav
*.dta
*.xlsx
*.xls

# Exceptions: the dictionary outputs ARE part of the public repo.
!docs/data-dictionary.csv
!docs/data-dictionary.json

# PDFs — survey flow docs stay local, not in the public repo
/r/docs/
*.pdf

# Audit artifacts — annotated scripts, audit reports, runtime captures,
# and phase-N verification harnesses all live in M:\MM\Websites\strata-local\audit\
# (Matt's local-only working notes). Belt-and-suspenders patterns here so they
# can't accidentally creep back into the public repo.
docs/audit/
docs/AUDIT_REPORT.md
docs/PHASE*_VERIFICATION*.txt
docs/PHASE*_TEST_*.txt
docs/PHASE*_READER_*.txt
scripts/phase*_verify*.R
scripts/phase*_test_*.R
scripts/phase*_recheck_*.R

# Claude Code local override file (per-user, never commit). The shared
# .claude/settings.json IS committed.
.claude/settings.local.json

# Node / Next.js
node_modules/
.next/
out/
.vercel/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/coverage
/build
*.tsbuildinfo
next-env.d.ts
*.pem

# Playwright MCP screenshots — UI verification artifacts stay local
# (matches the broader Strata convention of keeping audit artifacts
# under M:\MM\Websites\strata-local\audit\)
.playwright-mcp/
*.png
# …but public/images holds real site assets (favicons, illustrations) that
# must ship, so re-include PNGs in that folder.
!public/images/*.png

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# R artifacts
.Rhistory
.RData
.Ruserdata
*.Rproj.user/

# OS
.DS_Store
Thumbs.db

# LibreOffice / OpenOffice lock files (e.g., docs/.~lock.data-dictionary.csv#)
.~lock.*#

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor
.vscode/
.idea/

# JSON outputs ARE committed — they are the precomputed data the app serves
# Do not add /public/data/ to this file
